{
  "name": "waldritter-project-db",
  "version": "1.0.0",
  "description": "WordPress plugin for Waldritter Project Database integration",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass src/shared/styles.scss assets/css/frontend.css --style=compressed && sass src/shared/editor.scss assets/css/editor.css --style=compressed",
    "build:js": "esbuild src/widgets/**/index.js --bundle --outdir=assets/js --minify",
    "watch": "npm-run-all --parallel watch:*",
    "watch:css": "sass --watch src/shared:assets/css",
    "watch:js": "esbuild src/widgets/**/index.js --bundle --outdir=assets/js --watch",
    "test": "npm run test:php && npm run test:js",
    "test:php": "composer test",
    "test:js": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "dependencies": {
    "marked": "^9.0.0"
  },
  "devDependencies": {
    "@wordpress/scripts": "^26.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.69.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "<rootDir>/tests/js/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/js/setup.js"
    ],
    "moduleNameMapper": {
      "\\.(css|scss)$": "<rootDir>/tests/js/__mocks__/styleMock.js"
    }
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "env": {
      "browser": true,
      "es6": true,
      "jest": true
    },
    "globals": {
      "wp": "readonly",
      "waldritterProjectDB": "readonly"
    }
  }
}
