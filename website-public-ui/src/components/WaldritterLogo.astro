---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`relative ${className}`}>
  <svg viewBox="0 0 200 200" class="w-full h-full animate-wald-spin" style="animation-duration: 30s;">
    <defs>
      <linearGradient id="wald-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#1BAE70" />
        <stop offset="100%" stop-color="#D4A017" />
      </linearGradient>
      <!-- Dragon cutout mask -->
      <mask id="leaf-mask">
        <rect width="200" height="200" fill="white" />
        <!-- Dragon silhouette (heraldic rampant) carved out of leaf -->
        <g fill="black" transform="translate(100,95) scale(0.52)">
          <!-- Head with crest -->
          <path d="M-5,-75 L-2,-82 L5,-85 L10,-80 L12,-72 L8,-68 L2,-65 L-3,-68 Z" />
          <!-- Jaw/snout -->
          <path d="M-3,-68 L-12,-62 L-10,-58 L-2,-60 L2,-65 Z" />
          <!-- Head crest/horn -->
          <path d="M5,-85 L3,-95 L10,-90 L12,-80 Z" />
          <!-- Neck -->
          <path d="M2,-65 L8,-68 L12,-55 L8,-42 L2,-45 L-2,-55 Z" />
          <!-- Torso -->
          <path d="M-2,-45 L8,-42 L14,-20 L10,5 L-5,5 L-10,-18 Z" />
          <!-- Left wing (spread) -->
          <path d="M-10,-42 L-25,-65 L-40,-78 L-35,-68 L-50,-75 L-42,-62 L-58,-65 L-48,-52 L-60,-50 L-45,-40 L-30,-35 L-18,-32 L-10,-30 Z" />
          <!-- Right wing (spread) -->
          <path d="M14,-42 L28,-65 L42,-78 L37,-68 L52,-75 L44,-62 L60,-65 L50,-52 L62,-50 L47,-40 L32,-35 L20,-32 L14,-30 Z" />
          <!-- Left arm -->
          <path d="M-10,-18 L-22,-22 L-25,-15 L-28,-18 L-26,-12 L-18,-8 L-10,-10 Z" />
          <!-- Right arm -->
          <path d="M14,-18 L24,-22 L27,-15 L30,-18 L28,-12 L20,-8 L14,-10 Z" />
          <!-- Left leg -->
          <path d="M-5,5 L-12,20 L-18,30 L-22,28 L-16,20 L-20,22 L-14,15 L-8,10 Z" />
          <!-- Right leg -->
          <path d="M10,5 L16,20 L22,30 L26,28 L20,20 L24,22 L18,15 L12,10 Z" />
          <!-- Tail -->
          <path d="M0,5 L-2,18 L0,35 L3,50 L5,62 L8,68 L10,60 L6,48 L4,35 L3,18 L5,5 Z" />
          <!-- Tail tip (arrow/spade) -->
          <path d="M8,68 L4,75 L8,82 L12,75 Z" />
        </g>
      </mask>
    </defs>
    <!-- Maple leaf silhouette with dragon cut out -->
    <g mask="url(#leaf-mask)">
      <path
        fill="url(#wald-grad)"
        d="
          M100,8
          L108,28 L118,22 L114,38
          L135,30 L128,45 L145,42
          L130,58 L155,55 L138,68
          L162,72 L140,80 L158,90
          L135,88 L142,100
          L125,95 L128,108
          L115,98 L115,115
          L108,102 L105,118
          L100,105
          L95,118 L92,102
          L85,115 L85,98
          L72,108 L75,95
          L58,100 L65,88
          L42,90 L60,80
          L38,72 L62,68
          L45,55 L70,58
          L55,42 L72,45
          L65,30 L86,38
          L82,22 L92,28
          Z
        "
      />
    </g>
    <!-- Stem -->
    <path
      fill="url(#wald-grad)"
      d="M98,118 L97,155 L95,165 L100,160 L105,165 L103,155 L102,118 Z"
    />
  </svg>
</div>
