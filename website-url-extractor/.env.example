# Anthropic API Key for LLM
ANTHROPIC_API_KEY=sk-ant-...

# Google API Key for image generation (get from https://aistudio.google.com/)
GOOGLE_API_KEY=your-google-ai-studio-key

# LLM Model (claude-3-5-haiku-latest for speed, claude-sonnet-4-20250514 for quality)
DSPY_LM_MODEL=claude-3-5-haiku-latest

# Image generation settings (imagen-4.0-generate-001, imagen-4.0-fast-generate-001, or imagen-4.0-ultra-generate-001)
IMAGE_MODEL=imagen-4.0-generate-001
IMAGE_ASPECT_RATIO=1:1

# Safety limits (LLM decides when to stop, these are maximums)
EXPLORER_MAX_PAGES=8
EXPLORER_MAX_DEPTH=3
EXPLORER_MIN_CONFIDENCE=0.7

# Scraper settings
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3

# Tag matching
TAG_MATCH_THRESHOLD=0.3
