---
import PageLayout from '../../layouts/PageLayout.astro';
import GlitchHeading from '../../components/GlitchHeading.astro';
import HologramImage from '../../components/HologramImage.astro';
import TagBadge from '../../components/TagBadge.astro';
import SectionPanel from '../../components/SectionPanel.astro';
import { fetchProject } from '../../lib/graphql';
import { formatDate, formatDateRange } from '../../lib/date-utils';
import { marked } from 'marked';

const { id } = Astro.params;
const project = await fetchProject(id!);

if (!project) {
  return Astro.redirect('/projects/');
}

const upcomingOccurrences = (project.occurrences || [])
  .filter(o => o.startDate && new Date(o.startDate) >= new Date())
  .slice(0, 5);
---

<PageLayout title={`${project.title} — WALDRITTER`}>
  <section class="px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-5xl mx-auto">
      <!-- Breadcrumb -->
      <div class="mb-8 flex items-center gap-2 text-xs font-mono text-gray-500">
        <a href="/projects/" class="hover:text-wald-300 transition-colors">Projekte</a>
        <span>/</span>
        <span class="text-gray-400">{project.title}</span>
      </div>

      <!-- Header with hologram image -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <div>
          <GlitchHeading text={project.title} tag="h1" class="text-2xl md:text-4xl mb-6" />

          {project.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map(tag => (
                <TagBadge
                  title={tag.title}
                  href={`/projects/?tags=${encodeURIComponent(tag.title)}`}
                />
              ))}
            </div>
          )}

          {project.homepage && (
            <a
              href={project.homepage}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-mono text-ritter-400 hover:text-ritter-300 transition-colors mb-6"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-ritter-400"></span>
              Homepage besuchen &rarr;
            </a>
          )}
        </div>

        {project.imageUrl ? (
          <HologramImage
            src={project.imageUrl}
            alt={project.title}
            intensity="high"
            class="aspect-video rounded-lg"
          />
        ) : (
          <div class="aspect-video bg-wald-950/80 rounded-lg flex items-center justify-center glow-border">
            <span class="font-display text-wald-700 text-xs tracking-[0.3em]">KEIN BILD</span>
          </div>
        )}
      </div>

      <!-- Description -->
      {project.description && (
        <SectionPanel class="mb-8">
          <p class="font-mono text-xs text-gray-500 mb-3">BESCHREIBUNG</p>
          <div class="text-gray-300 font-body leading-relaxed prose prose-invert prose-sm prose-a:text-wald-300 prose-a:no-underline hover:prose-a:text-wald-200 prose-headings:font-display prose-headings:tracking-wider max-w-none" set:html={marked.parse(project.description)} />
        </SectionPanel>
      )}

      <!-- Upcoming Events -->
      {upcomingOccurrences.length > 0 && (
        <SectionPanel class="mb-8">
          <p class="font-mono text-xs text-gray-500 mb-4">KOMMENDE TERMINE</p>
          <div class="space-y-3">
            {upcomingOccurrences.map(occ => (
              <div class="flex items-center gap-3 text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-ritter-400 animate-pulse"></span>
                <span class="font-mono text-ritter-300">
                  {formatDateRange(occ.startDate, occ.endDate)}
                </span>
              </div>
            ))}
          </div>
        </SectionPanel>
      )}

      <!-- Back link -->
      <div class="mt-12">
        <a href="/projects/" class="nav-link text-sm">&larr; Alle Projekte</a>
      </div>
    </div>
  </section>
</PageLayout>
