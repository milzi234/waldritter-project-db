---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'WALDRITTER — Projektdatenbank',
  description = 'Waldritter e.V. Projektdatenbank — Bildung, Abenteuer, Gemeinschaft.',
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="scanlines grid-bg min-h-screen">
    <!-- Ambient glow orbs -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0" aria-hidden="true">
      <div class="absolute -top-40 -left-40 w-96 h-96 bg-wald-500/20 rounded-full animate-glow-pulse blur-3xl"></div>
      <div class="absolute top-1/3 -right-40 w-80 h-80 bg-ritter-500/15 rounded-full animate-glow-pulse blur-3xl" style="animation-delay: 1.5s;"></div>
      <div class="absolute -bottom-40 left-1/3 w-72 h-72 bg-wald-700/10 rounded-full animate-glow-pulse blur-3xl" style="animation-delay: 3s;"></div>
    </div>

    <!-- Scan line -->
    <div class="fixed inset-0 pointer-events-none z-50 overflow-hidden" aria-hidden="true">
      <div class="w-full h-px bg-gradient-to-r from-transparent via-wald-400/20 to-transparent animate-scan-line"></div>
    </div>

    <div class="relative z-10">
      <slot />
    </div>

    <script>
      let glitchTimer: ReturnType<typeof setTimeout> | null = null;

      function initGlitch() {
        if (glitchTimer) clearTimeout(glitchTimer);
        const body = document.body;

        function triggerGlitch() {
          const intensity = 0.3 + Math.random() * 0.7;
          body.style.setProperty('--glitch-intensity', intensity.toFixed(2));
          body.classList.add('glitching');

          const duration = 200 + intensity * 300;
          setTimeout(() => {
            body.classList.remove('glitching');
            scheduleNext();
          }, duration);
        }

        function scheduleNext() {
          const delay = 8000 + Math.random() * 25000;
          glitchTimer = setTimeout(triggerGlitch, delay);
        }

        glitchTimer = setTimeout(triggerGlitch, 4000 + Math.random() * 10000);
      }

      document.addEventListener('astro:page-load', initGlitch);
    </script>
  </body>
</html>
