---
import WaldritterLogo from './WaldritterLogo.astro';

const navItems = [
  { label: 'Projekte', href: '/projects/' },
  { label: 'Themen', href: '/tags/' },
  { label: 'Info', href: '/about' },
];
---

<nav class="fixed top-0 w-full z-40 backdrop-blur-md bg-black/70 border-b border-wald-500/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <WaldritterLogo class="w-8 h-8" />
        <span class="font-display text-sm tracking-[0.3em] text-gray-300 group-hover:text-wald-300 transition-colors">
          WALDRITTER
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </div>

      <!-- Status indicator -->
      <div class="hidden md:flex items-center gap-2 text-xs font-mono text-gray-500">
        <span class="w-1.5 h-1.5 rounded-full bg-wald-400 animate-pulse"></span>
        <span>SYS::ONLINE</span>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-gray-400 hover:text-wald-300 transition-colors"
        aria-label="Menü umschalten"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-wald-500/10 bg-black/90 backdrop-blur-md">
    <div class="px-4 py-4 space-y-3">
      {navItems.map((item) => (
        <a href={item.href} class="block nav-link py-2">{item.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
    // Ensure menu is closed after navigation
    menu?.classList.add('hidden');
  });
</script>
